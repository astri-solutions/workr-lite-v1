# ── Workr Lite — Environment Variables ───────────────────────────────────────
# Copie este arquivo para .env e preencha os valores antes de subir o Docker.
# Nunca commite o .env com credenciais reais.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=workrlite
POSTGRES_USER=workr
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# ── API (Go) ──────────────────────────────────────────────────────────────────
APP_ENV=production
# Segredo JWT — gerar com: openssl rand -hex 32
APP_SECRET=CHANGE_ME_jwt_secret_32_chars

# CORS — domínio(s) do painel admin, separados por vírgula
CORS_ORIGINS=https://admin.seudominio.com.br

# ── Email (Postmark) ──────────────────────────────────────────────────────────
# Obtenha o token em: https://account.postmarkapp.com/servers
POSTMARK_SERVER_TOKEN=CHANGE_ME
POSTMARK_FROM_EMAIL=noreply@seudominio.com.br
POSTMARK_FROM_NAME=Workr Lite

# ── Storage de arquivos ───────────────────────────────────────────────────────
# "local" = salva em /app/uploads dentro do container (volume Docker)
# "s3"    = S3 ou compatível (Cloudflare R2, Wasabi, etc.)
STORAGE_DRIVER=local

# Só necessário se STORAGE_DRIVER=s3
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=        # deixe vazio para AWS; preencha para R2/Wasabi/etc.

# ── CVM (dados abertos) ───────────────────────────────────────────────────────
CVM_API_BASE_URL=https://dados.cvm.gov.br/api/dados/

# ── VPS / Domínio (para o Nginx + Certbot) ───────────────────────────────────
DOMAIN=seudominio.com.br
ADMIN_DOMAIN=admin.seudominio.com.br
CERTBOT_EMAIL=seu@email.com.br
